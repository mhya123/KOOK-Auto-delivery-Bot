
# =========================
# KOOK Bot 基础配置
# =========================
# 机器人 Token
KOOK_BOT_TOKEN=your-token-here

# 命令前缀，例如 /help、/buy
KOOK_COMMAND_PREFIX=/

# 充值卡生成格式
# 支持占位符：
# {random}    随机字符串
KOOK_RECHARGE_CARD_FORMAT=MhYa123-{random}

# {random} 的长度
KOOK_RECHARGE_CARD_RANDOM_LENGTH=16

# {random} 使用的字符集
KOOK_RECHARGE_CARD_ALPHABET=ABCDEFGHJKLMNPQRSTUVWXYZ23456789

# =========================
# 内置支付配置
# =========================
# 是否启用内置码/易支付
KOOK_PAYMENT_ENABLED=false

# 支付网关地址
KOOK_PAYMENT_API_BASE_URL=https://XXXXXX.com/

# 商户 PID
KOOK_PAYMENT_PID=

# 商户密钥
KOOK_PAYMENT_KEY=

# 下单显示的网站名称
KOOK_PAYMENT_SITENAME=KOOK Auto-delivery Bot

# 支付回调对外访问地址
# 留空时默认复用 KOOK_IMPORT_WEB_BASE_URL
KOOK_PAYMENT_BASE_URL=

# 支付异步回调路径
KOOK_PAYMENT_NOTIFY_PATH=/payment/notify

# 支付同步跳转路径
KOOK_PAYMENT_RETURN_PATH=/payment/return

# 是否允许用户手动输入自定义充值金额
KOOK_PAYMENT_ALLOW_CUSTOM_AMOUNT=false

# 自定义充值金额最小值
KOOK_PAYMENT_CUSTOM_AMOUNT_MIN=1

# 自定义充值金额最大值
KOOK_PAYMENT_CUSTOM_AMOUNT_MAX=100000

# 机器人默认语言，例如 zh-CN、en-US
KOOK_LOCALE=zh-CN

# 外置语言文件目录
KOOK_LOCALE_DIR=locales


# =========================
# 权限与频道配置
# =========================
# 管理员命令专用频道 ID
# 留空则不限制管理员命令频道
KOOK_ADMIN_COMMAND_CHANNEL_ID=7382444605314930

# 日志推送频道 ID
# 留空则不推送频道日志
KOOK_LOG_CHANNEL_ID=8017881393570156

# Gateway 应用层心跳发送间隔，单位秒
KOOK_GATEWAY_PING_INTERVAL_SECONDS=30

# Gateway 心跳发送抖动范围，单位秒
KOOK_GATEWAY_PING_JITTER_SECONDS=5

# Gateway 等待 PONG 的超时时间，单位秒
KOOK_GATEWAY_PONG_TIMEOUT_SECONDS=12

# 连续丢失多少次 PONG 后才断线重连
KOOK_GATEWAY_MAX_MISSED_PONGS=2

# 超级管理员用户 ID，多个用英文逗号分隔
KOOK_SUPER_ADMIN_IDS=2744428583

# 允许运行时热更改配置的管理员 ID，多个用英文逗号分隔
# 只有这里配置的管理员才能看到和使用 /settings 以及相关热更改命令
# 留空时默认继承 KOOK_SUPER_ADMIN_IDS
KOOK_RUNTIME_CONFIG_ADMIN_IDS=2744428583


# =========================
# 数据库配置
# =========================
# 可选：sqlite / mysql
KOOK_DB_BACKEND=sqlite

# SQLite 数据库文件路径
KOOK_SQLITE_PATH=data/kook-bot.db

# MySQL 主机
KOOK_MYSQL_HOST=127.0.0.1

# MySQL 端口
KOOK_MYSQL_PORT=3306

# MySQL 用户名
KOOK_MYSQL_USER=root

# MySQL 密码
KOOK_MYSQL_PASSWORD=

# MySQL 数据库名
KOOK_MYSQL_DATABASE=kook_bot


# =========================
# 日志配置
# =========================
# 日志级别：DEBUG / INFO / WARNING / ERROR
KOOK_LOG_LEVEL=INFO

# 是否输出 KOOK HTTP 请求日志
KOOK_LOG_HTTP=false

# 是否输出 Gateway 原始事件日志
KOOK_LOG_EVENTS=false

# 是否输出正常命令触发日志
KOOK_LOG_COMMANDS=false

# 是否输出命令执行状态日志
KOOK_LOG_COMMAND_STATUS=false

# 是否输出导入链路详细日志
KOOK_LOG_IMPORTS=false

# 是否启用普通用户命令/按钮点击限流
# 管理员和超级管理员默认不受此限制
KOOK_USER_COMMAND_COOLDOWN_ENABLED=true

# 普通用户默认命令冷却秒数
KOOK_USER_COMMAND_COOLDOWN_SECONDS=3

# 指定命令单独冷却秒数，格式：命令:秒数,命令:秒数
# 默认推荐：help:2,pay_amounts:2,products:2,buy:5,recharge:5,pay:8
KOOK_USER_COMMAND_COOLDOWN_OVERRIDES=help:2,pay_amounts:2,products:2,buy:5,recharge:5,pay:8

# 是否写入日志文件
KOOK_LOG_TO_FILE=true

# 日志目录
KOOK_LOG_DIR=logs

# 日志文件名
KOOK_LOG_FILE=kook-bot.log

# 单个日志文件最大字节数，超过后自动切分
KOOK_LOG_MAX_BYTES=5242880

# 最多保留多少份旧日志
KOOK_LOG_BACKUP_COUNT=7


# =========================
# 网页导入配置
# =========================
# 是否启用一次性网页上传导入
KOOK_IMPORT_WEB_ENABLED=true

# 网页上传监听地址
KOOK_IMPORT_WEB_HOST=127.0.0.1

# 网页上传监听端口
KOOK_IMPORT_WEB_PORT=18080

# 网页上传对外访问地址
# 如果要给外网访问，这里应改成域名或公网 IP
KOOK_IMPORT_WEB_BASE_URL=http://127.0.0.1:18080

# 网页上传链接有效期，单位秒
KOOK_IMPORT_WEB_TTL_SECONDS=600

# 网页上传最大体积，单位 MB
KOOK_IMPORT_WEB_MAX_BODY_MB=50
